# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/heirrati
# If Atlas SRV fails on Windows (SSL/DNS), set MONGODB_URI_STANDARD with standard format from Atlas
# MONGODB_URI_STANDARD=mongodb://user:pass@cluster0-shard-00-00.xxx.mongodb.net:27017,.../db?ssl=true&replicaSet=atlasxxx-shard-0&authSource=admin
# MONGODB_REPLICA_SET=atlasbmo5vuw-shard-0  # Override if auto-detection fails

# JWT
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars

# Production (Render) - set these in Render dashboard
# API_BASE_URL=https://heirring-com-5.onrender.com
# FRONTEND_URL=https://your-vercel-app.vercel.app

# OAuth - Google Cloud Console
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
